PORT=3000
# auto: usa Supabase y cae a SQLite si Supabase falla.
# sqlite: solo local, no sirve para compartir con otra ciudad.
# supabase: solo Supabase; falla si el proyecto esta pausado.
DATA_SOURCE=auto
SESSION_SECRET=cambia_esto_por_un_texto_largo
# Opcional: si lo configuras en Render, tambien ponlo como secret de GitHub.
MAINTENANCE_TOKEN=cambia_esto_por_otro_texto_largo

# Supabase: se usa para produccion, importar y crear backups.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_service_role_key

# Opcional: solo si quieres activar realtime en el navegador.
SUPABASE_PUBLIC_KEY=tu_anon_o_publishable_key
